          <!-- Wave 1 -->
          <path d="M-40,96 Q0,80 40,96 Q80,112 120,96 Q160,80 200,96 Q240,112 250,96 L250,300 L-40,300 Z"
                fill="rgba(100,210,255,.28)">
            <animateTransform attributeName="transform" type="translate"
              values="0,0;-60,0;0,0" dur="5s" repeatCount="indefinite"/>
          </path>
          <!-- Wave 2 -->
          <path d="M-40,90 Q10,76 50,90 Q90,104 130,90 Q170,76 220,90 L220,300 L-40,300 Z"
                fill="rgba(130,220,255,.15)">
            <animateTransform attributeName="transform" type="translate"
              values="0,0;55,0;0,0" dur="7.5s" repeatCount="indefinite"/>
          </path>
          <!-- Depth shimmer dots -->
          <circle cx="58"  cy="175" r="3" fill="rgba(255,255,255,.18)">
            <animate attributeName="opacity" values=".18;.5;.18" dur="2.8s" repeatCount="indefinite"/>
          </circle>
          <circle cx="128" cy="218" r="2.2" fill="rgba(255,255,255,.13)">
            <animate attributeName="opacity" values=".12;.4;.12" dur="3.6s" repeatCount="indefinite"/>
          </circle>
          <circle cx="88"  cy="252" r="2.6" fill="rgba(255,255,255,.15)">
            <animate attributeName="opacity" values=".15;.45;.15" dur="4.4s" repeatCount="indefinite"/>
          </circle>
        </g>

        <!-- Water in neck -->
        <g clip-path="url(#kNeckClip)">
          <rect x="66" y="38" width="68" height="46" fill="url(#kWater)"/>
        </g>

        <!-- ── Glass body ── -->
        <path d="M52,80 C48,80 36,96 34,144 L28,270 Q27,286 52,286 L148,286 Q173,286 172,270 L166,144 C164,96 152,80 148,80 Z"
              fill="url(#kGlass)" filter="url(#kShadow)"/>

        <!-- Body outline -->
        <path d="M52,80 C48,80 36,96 34,144 L28,270 Q27,286 52,286 L148,286 Q173,286 172,270 L166,144 C164,96 152,80 148,80 Z"
              fill="none" stroke="rgba(80,190,255,.55)" stroke-width="1.6"/>

        <!-- Left highlight -->
        <path d="M55,90 C51,90 41,104 38,150 L34,238"
              fill="none" stroke="rgba(255,255,255,.48)" stroke-width="3" stroke-linecap="round"/>
        <!-- Secondary inner highlight -->
        <path d="M64,86 L62,190"
              fill="none" stroke="rgba(255,255,255,.15)" stroke-width="1.3" stroke-linecap="round"/>

        <!-- ── Neck ── -->
        <rect x="66" y="38" width="68" height="46" rx="9"
              fill="url(#kGlass)" stroke="rgba(80,190,255,.55)" stroke-width="1.6"/>
        <path d="M68,42 L68,80" fill="none" stroke="rgba(255,255,255,.28)" stroke-width="1.8" stroke-linecap="round"/>

        <!-- ── Rim ── -->
        <ellipse cx="100" cy="40" rx="38" ry="7.5"
              fill="rgba(60,160,240,.2)" stroke="rgba(80,190,255,.6)" stroke-width="1.6"/>
        <path d="M64,38 Q100,30 136,38" fill="none" stroke="rgba(255,255,255,.38)" stroke-width="1.8" stroke-linecap="round"/>

        <!-- ── Handle ── -->
        <path d="M164,118 Q204,118 204,162 Q204,206 164,206"
              fill="none" stroke="rgba(80,190,255,.5)" stroke-width="2.5" stroke-linecap="round"/>
        <path d="M164,123 Q199,123 199,162 Q199,200 164,200"
              fill="none" stroke="rgba(255,255,255,.18)" stroke-width="1.2" stroke-linecap="round"/>

        <!-- ── Base shadow ── -->
        <ellipse cx="100" cy="287" rx="64" ry="7" fill="rgba(0,20,60,.45)"/>
      </svg>

      <div class="jug-items" id="knowItems">
        <div class="empty-hint">Your strengths &amp;<br/>certainties live here</div>
      </div>
    </div>
    <div class="count-lbl" id="knowCount">0 things</div>
  </div>
</div>

<!-- ══════════════ BALANCE JUG ══════════════ -->
<div class="balance-sec">
  <div class="jug-label balance">My Overall Balance</div>
  <div class="jug-wrap balance-wrap" id="balWrap">
    <svg class="jug-svg" id="balSVG" viewBox="0 0 260 220" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <clipPath id="bBodyClip">
          <path d="M38,56 C34,56 24,68 22,104 L16,196 Q15,210 38,210 L222,210 Q245,210 244,196 L238,104 C236,68 226,56 222,56 Z"/>
        </clipPath>
        <linearGradient id="bWater" x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%"   stop-color="#62c8ff"/>
          <stop offset="50%"  stop-color="#1e90d8"/>
          <stop offset="100%" stop-color="#0e62a8"/>
        </linearGradient>
        <linearGradient id="bGlass" x1="0" y1="0" x2="1" y2="0">
          <stop offset="0%"   stop-color="rgba(255,255,255,.22)"/>
          <stop offset="13%"  stop-color="rgba(255,255,255,.06)"/>
          <stop offset="87%"  stop-color="rgba(255,255,255,.03)"/>
          <stop offset="100%" stop-color="rgba(255,255,255,.14)"/>
        </linearGradient>
        <filter id="bShadow" x="-10%" y="-8%" width="120%" height="130%">
          <feDropShadow dx="0" dy="5" stdDeviation="9" flood-color="rgba(0,20,60,.6)"/>
