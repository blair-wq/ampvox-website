      </defs>

      <!-- Water (y set by JS) -->
      <g clip-path="url(#bBodyClip)">
        <rect id="balWaterRect" x="0" y="210" width="260" height="220" fill="url(#bWater)"/>
        <!-- Wave group: vertical offset by JS, horizontal animated -->
        <g id="balWaveG">
          <path d="M-40,158 Q20,144 80,158 Q140,172 200,158 Q260,144 310,158 L310,230 L-40,230 Z"
                fill="rgba(100,215,255,.35)">
            <animateTransform attributeName="transform" type="translate"
              values="0,0;-70,0;0,0" dur="4.5s" repeatCount="indefinite"/>
          </path>
        </g>
      </g>

      <!-- Glass body -->
      <path d="M38,56 C34,56 24,68 22,104 L16,196 Q15,210 38,210 L222,210 Q245,210 244,196 L238,104 C236,68 226,56 222,56 Z"
            fill="url(#bGlass)" filter="url(#bShadow)"/>
      <path d="M38,56 C34,56 24,68 22,104 L16,196 Q15,210 38,210 L222,210 Q245,210 244,196 L238,104 C236,68 226,56 222,56 Z"
            fill="none" stroke="rgba(100,200,255,.45)" stroke-width="1.6"/>

      <!-- Left highlight -->
      <path d="M41,64 C37,64 28,74 25,108 L20,188"
            fill="none" stroke="rgba(255,255,255,.42)" stroke-width="3" stroke-linecap="round"/>
      <path d="M54,60 L52,185"
            fill="none" stroke="rgba(255,255,255,.12)" stroke-width="1.3" stroke-linecap="round"/>

      <!-- Neck (wide bowl opening) -->
      <rect x="76" y="26" width="108" height="34" rx="9"
            fill="rgba(60,140,220,.1)" stroke="rgba(100,200,255,.45)" stroke-width="1.6"/>
      <path d="M78,26 L78,58" fill="none" stroke="rgba(255,255,255,.2)" stroke-width="1.6" stroke-linecap="round"/>

      <!-- Rim -->
      <ellipse cx="130" cy="28" rx="57" ry="9"
            fill="rgba(60,160,240,.18)" stroke="rgba(100,200,255,.55)" stroke-width="1.6"/>
      <path d="M74,26 Q130,16 186,26" fill="none" stroke="rgba(255,255,255,.32)" stroke-width="1.7" stroke-linecap="round"/>

      <!-- Handles (both sides for a wider jug) -->
      <path d="M238,90 Q260,90 260,124 Q260,158 238,158"
            fill="none" stroke="rgba(100,200,255,.42)" stroke-width="2.2" stroke-linecap="round"/>
      <path d="M22,90 Q0,90 0,124 Q0,158 22,158"
            fill="none" stroke="rgba(100,200,255,.42)" stroke-width="2.2" stroke-linecap="round"/>

      <!-- Base -->
      <ellipse cx="130" cy="210" rx="96" ry="8" fill="rgba(0,20,60,.4)"/>
    </svg>
  </div>
  <div class="balance-note" id="balNote">Add items to both jugs to see your balance</div>
</div>

<!-- ══════════════ INPUT PANEL ══════════════ -->
<div class="panel">
  <h3>Add something to your dashboard:</h3>
  <div class="inp-row">
    <input type="text" id="textInput"
           placeholder="e.g.  I communicate really well with people…"
           onkeydown="handleKey(event)"/>
  </div>
  <div class="btn-row">
    <button class="btn btn-change" onclick="addItem('change')">← I'd like to change this</button>
    <button class="btn btn-know"   onclick="addItem('know')">I know &amp; have this →</button>
  </div>
</div>

<script>
/* ── State ───────────────────────────────── */
const S = { know:[], change:[] };
let dragging = null;

/* ── Balance jug geometry (viewBox 0 0 260 220) ── */
const BAL = { top:56, bottom:210 }; // y-range of jug body

/* ── Add ─────────────────────────────────── */
function addItem(jug) {
  const inp = document.getElementById('textInput');
  const txt = inp.value.trim();
  if (!txt) { inp.focus(); return; }
  S[jug].push({ id: Date.now() + Math.random(), text: txt });
  inp.value = '';
  inp.focus();
  render(jug);
  updateBalance();
  boing(jug === 'know' ? 'knowWrap' : 'changeWrap');
}

function handleKey(e) { if (e.key==='Enter') addItem('know'); }

/* ── Remove ──────────────────────────────── */
function removeItem(jug, id) {
  S[jug] = S[jug].filter(i => i.id !== id);
  render(jug);
  updateBalance();
}

/* ── Render items ────────────────────────── */
function render(jug) {
  const el    = document.getElementById(jug==='know' ? 'knowItems'   : 'changeItems');
  const badge = document.getElementById(jug==='know' ? 'knowCount'   : 'changeCount');
  const items = S[jug];

  el.innerHTML = '';

  // Hint
  const hint = document.createElement('div');
  hint.className = 'empty-hint';
  hint.innerHTML = jug === 'know'
    ? 'Your strengths &amp;<br/>certainties live here'
    : "Things you'd like<br/>to work on";
  el.appendChild(hint);

  if (items.length) el.classList.add('filled');
  else el.classList.remove('filled');

  items.forEach(item => {
    const t = document.createElement('div');
    t.className = `tag in-${jug}`;
    t.draggable = true;
    t.dataset.id  = item.id;
    t.dataset.jug = jug;
    t.innerHTML = `<span>${esc(item.text)}</span>
      <button class="del" onclick="removeItem('${jug}',${item.id})">✕</button>`;
    t.addEventListener('dragstart', e => {
      dragging = { id: item.id, fromJug: jug };
      e.dataTransfer.effectAllowed = 'move';
      setTimeout(() => t.style.opacity = '.3', 0);
    });
    t.addEventListener('dragend', () => { t.style.opacity='1'; dragging=null; });
    el.appendChild(t);
  });

  const n = items.length;
  badge.textContent = n===0 ? '0 things' : n===1 ? '1 thing' : `${n} things`;
}

/* ── Balance jug water update ────────────── */
let balCurrentY = BAL.bottom; // starts empty

function updateBalance() {
  const kn = S.know.length;
  const ch = S.change.length;
  const total = kn + ch;

  const fill = total === 0 ? 0 : kn / total;
  const h = BAL.bottom - BAL.top;
  const targetY = BAL.bottom - fill * h;

  animateBalWater(targetY);

  const note = document.getElementById('balNote');
  if (total === 0) {
    note.textContent = 'Add items to both jugs to see your balance';
  } else if (fill === 1) {
    note.textContent = `All ${kn} things are in "know & have" — wonderful ✨`;
  } else if (fill === 0) {
    note.textContent = `All ${ch} things are in "change" — keep reflecting`;
  } else {
    const pct = Math.round(fill * 100);
    note.textContent = `${kn} known  ·  ${ch} to change  ·  ${pct}% full`;
  }
}

function animateBalWater(targetY) {
  const rect  = document.getElementById('balWaterRect');
  const waveG = document.getElementById('balWaveG');
  const startY = balCurrentY;
  const dur = 900;
  const t0 = performance.now();

  // Baseline wave path is centered around y≈158 in the viewBox
  const WAVE_BASE_Y = 158;

  function step(now) {
    const p = Math.min((now - t0) / dur, 1);
    // ease-in-out cubic
    const e = p < .5 ? 4*p*p*p : 1 - Math.pow(-2*p+2,3)/2;
    const y = startY + (targetY - startY) * e;

    rect.setAttribute('y', y);
    // Shift wave group vertically so wave sits at water surface
    const offset = y - WAVE_BASE_Y;
    waveG.setAttribute('transform', `translate(0,${offset})`);

    if (p < 1) requestAnimationFrame(step);
    else balCurrentY = targetY;
  }
  requestAnimationFrame(step);
  balCurrentY = targetY; // update immediately so next call has correct start
}

/* ── Drag & drop ─────────────────────────── */
function jugDragOver(e, jug) {
  e.preventDefault();
  e.dataTransfer.dropEffect = 'move';
  document.getElementById(jug==='know' ? 'knowWrap' : 'changeWrap').classList.add('drag-on');
}
function jugDragLeave(e, jug) {
  document.getElementById(jug==='know' ? 'knowWrap' : 'changeWrap').classList.remove('drag-on');
}
function jugDrop(e, toJug) {
  e.preventDefault();
  jugDragLeave(e, toJug);
  if (!dragging || dragging.fromJug === toJug) return;
  const item = S[dragging.fromJug].find(i => i.id === dragging.id);
  if (!item) return;
  S[dragging.fromJug] = S[dragging.fromJug].filter(i => i.id !== dragging.id);
  S[toJug].push(item);
  render(dragging.fromJug);
  render(toJug);
  updateBalance();
  boing(toJug==='know' ? 'knowWrap' : 'changeWrap');
  dragging = null;
}

/* ── Boing ───────────────────────────────── */
function boing(id) {
  const el = document.getElementById(id);
  el.style.transform = 'scale(1.07) translateY(-4px)';
  setTimeout(() => el.style.transform = '', 240);
}

/* ── HTML escape ─────────────────────────── */
function esc(s) {
  const d = document.createElement('div');
  d.appendChild(document.createTextNode(s));
  return d.innerHTML;
}
</script>
