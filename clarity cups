        <!-- Neck left highlight -->
        <path d="M68,42 L68,80" fill="none" stroke="rgba(255,255,255,.18)" stroke-width="1.8" stroke-linecap="round"/>

        <!-- ── Opening rim ── -->
        <ellipse cx="100" cy="40" rx="38" ry="7.5" fill="rgba(120,160,200,.1)" stroke="rgba(160,200,230,.36)" stroke-width="1.6"/>
        <path d="M64,38 Q100,30 136,38" fill="none" stroke="rgba(255,255,255,.22)" stroke-width="1.6" stroke-linecap="round"/>

        <!-- ── Handle ── -->
        <path d="M164,118 Q204,118 204,162 Q204,206 164,206"
              fill="none" stroke="rgba(160,200,230,.35)" stroke-width="2.5" stroke-linecap="round"/>
        <!-- Handle highlight -->
        <path d="M164,123 Q199,123 199,162 Q199,200 164,200"
              fill="none" stroke="rgba(255,255,255,.12)" stroke-width="1.2" stroke-linecap="round"/>

        <!-- ── Base shadow ── -->
        <ellipse cx="100" cy="287" rx="64" ry="7" fill="rgba(0,0,0,.3)"/>
      </svg>

      <div class="jug-items" id="changeItems">
        <div class="empty-hint">Things you'd like<br/>to work on</div>
      </div>
    </div>
    <div class="count-lbl" id="changeCount">0 things</div>
  </div>

  <!-- ── KNOW jug (right) ── -->
  <div class="jug-col">
    <div class="jug-label know">Things I know &amp; have</div>
    <div class="jug-wrap" id="knowWrap"
         ondragover="jugDragOver(event,'know')"
         ondragleave="jugDragLeave(event,'know')"
         ondrop="jugDrop(event,'know')">

      <svg class="jug-svg" viewBox="0 0 200 310" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <clipPath id="kBodyClip">
            <path d="M52,80 C48,80 36,96 34,144 L28,270 Q27,286 52,286 L148,286 Q173,286 172,270 L166,144 C164,96 152,80 148,80 Z"/>
          </clipPath>
          <clipPath id="kNeckClip">
            <rect x="66" y="38" width="68" height="46" rx="9"/>
          </clipPath>
          <linearGradient id="kWater" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%"   stop-color="#54c0ff"/>
            <stop offset="55%"  stop-color="#1a82cc"/>
            <stop offset="100%" stop-color="#0c5898"/>
          </linearGradient>
          <linearGradient id="kGlass" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="rgba(255,255,255,.24)"/>
            <stop offset="14%"  stop-color="rgba(255,255,255,.07)"/>
