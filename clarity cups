<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>My Clarity Dashboard</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&display=swap');
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

body {
  font-family:'Inter',system-ui,sans-serif;
  background: radial-gradient(ellipse at 25% 15%, #1c2d40 0%, #0e1c2c 55%, #07111c 100%);
  min-height:100vh;
  display:flex;flex-direction:column;align-items:center;
  padding:44px 20px 70px;
  color:#d8e8f4;
}

/* ── Header ─────────────────────────────── */
.hdr { text-align:center; margin-bottom:52px; }
.hdr h1 {
  font-size:2rem; font-weight:300; letter-spacing:.1em;
  color:#e8f4ff; margin-bottom:7px;
}
.hdr p { color:#4a7090; font-size:.88rem; letter-spacing:.06em; }

/* ── Top two jugs row ────────────────────── */
.top-row {
  display:flex; gap:90px; justify-content:center;
  flex-wrap:wrap; margin-bottom:52px;
}

/* ── Each jug column ─────────────────────── */
.jug-col { display:flex; flex-direction:column; align-items:center; }

.jug-label {
  font-size:.78rem; font-weight:500; letter-spacing:.1em;
  text-transform:uppercase; margin-bottom:14px; text-align:center;
}
.jug-label.change { color:#7a9cb8; }
.jug-label.know   { color:#55aae0; }
.jug-label.balance{ color:#6eb8e8; font-size:.72rem; }

/* ── Jug wrapper ─────────────────────────── */
.jug-wrap {
  position:relative; width:210px; height:320px;
  transition:transform .22s cubic-bezier(.34,1.56,.64,1),
             filter .22s ease;
}
.jug-wrap.balance-wrap { width:260px; height:220px; }
.jug-wrap.drag-on { filter:drop-shadow(0 0 12px rgba(80,180,255,.55)); }

/* SVG sits over everything */
.jug-svg { position:absolute; inset:0; width:100%; height:100%; pointer-events:none; z-index:3; }

/* Items scroll area inside jug */
.jug-items {
  position:absolute;
  left:38px; right:38px; top:92px; bottom:28px;
  overflow-y:auto; overflow-x:hidden;
  display:flex; flex-direction:column; justify-content:flex-end;
  gap:5px; padding:6px 4px; z-index:4;
}
.jug-items::-webkit-scrollbar{width:2px}
.jug-items::-webkit-scrollbar-thumb{background:rgba(255,255,255,.18);border-radius:2px}

.empty-hint {
  text-align:center; font-size:.67rem; color:rgba(255,255,255,.18);
  font-style:italic; line-height:1.7; padding:6px; pointer-events:none;
}
.jug-items.filled .empty-hint{display:none}

/* ── Item tags ───────────────────────────── */
.tag {
  border-radius:18px; padding:5px 26px 5px 11px;
  font-size:.73rem; line-height:1.45; word-break:break-word;
  position:relative; cursor:grab; user-select:none;
  transition:transform .12s, box-shadow .12s;
  animation:popIn .22s cubic-bezier(.34,1.56,.64,1) both;
}
@keyframes popIn {
  from{opacity:0;transform:scale(.55) translateY(10px)}
  to  {opacity:1;transform:scale(1)   translateY(0)}
}
.tag:hover{transform:scale(1.05)}
.tag.in-know {
  background:rgba(255,255,255,.88);
  border:1px solid rgba(255,255,255,.4);
  color:#0a3a58;
  box-shadow:0 1px 8px rgba(0,0,0,.25);
}
.tag.in-change {
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.14);
  color:#b0c8da;
  box-shadow:0 1px 5px rgba(0,0,0,.18);
}
.tag .del {
  position:absolute; right:7px; top:50%; transform:translateY(-50%);
  background:none; border:none; cursor:pointer;
  font-size:.58rem; color:rgba(255,255,255,.3);
  opacity:0; transition:opacity .15s; padding:2px; line-height:1;
}
.tag:hover .del{opacity:1}
.tag .del:hover{color:#ff7070}

.count-lbl {
  margin-top:10px; font-size:.7rem;
  color:#304050; letter-spacing:.04em;
}

/* ── Balance section ─────────────────────── */
.balance-sec { display:flex; flex-direction:column; align-items:center; margin-bottom:52px; }
.balance-note {
  margin-top:12px; font-size:.75rem; color:#3a6080; text-align:center;
  max-width:300px; line-height:1.6; letter-spacing:.02em;
}

/* ── Input panel ─────────────────────────── */
.panel {
  width:100%; max-width:600px;
  background:rgba(255,255,255,.04);
  backdrop-filter:blur(14px);
  border:1px solid rgba(255,255,255,.09);
  border-radius:22px; padding:28px 30px;
}
.panel h3 {
  font-size:.84rem; font-weight:400; color:#5a8aaa;
  margin-bottom:16px; letter-spacing:.04em;
}
.inp-row { display:flex; gap:10px; margin-bottom:14px; }
.inp-row input {
  flex:1; padding:12px 18px;
  background:rgba(255,255,255,.06); border:1px solid rgba(255,255,255,.12);
  border-radius:12px; font-size:.9rem; font-family:inherit;
  color:#d8eeff; outline:none;
  transition:border-color .2s, background .2s;
}
.inp-row input::placeholder{color:rgba(255,255,255,.22)}
.inp-row input:focus{border-color:rgba(80,180,255,.5);background:rgba(255,255,255,.09)}

.btn-row{display:flex;gap:12px}
.btn {
  flex:1; padding:12px 14px; border:none; border-radius:12px;
  font-size:.83rem; font-family:inherit; cursor:pointer; font-weight:500;
  letter-spacing:.02em;
  transition:transform .15s, box-shadow .15s, background .15s;
}
.btn:active{transform:scale(.96)!important}
.btn-change {
  background:rgba(255,255,255,.07);
  border:1px solid rgba(255,255,255,.14); color:#8aaec8;
}
.btn-change:hover{background:rgba(255,255,255,.12);transform:translateY(-1px)}
.btn-know {
  background:linear-gradient(135deg,#3aa8e8,#1462a8);
  color:#fff; box-shadow:0 3px 14px rgba(30,110,200,.28);
}
.btn-know:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(30,110,200,.4)}
.hint {
  text-align:center; font-size:.67rem;
  color:rgba(255,255,255,.18); margin-top:14px; letter-spacing:.03em;
}
</style>
</head>
<body>

<div class="hdr">
  <h1>My Clarity Dashboard</h1>
  <p>A space to understand where you stand</p>
</div>

<!-- ══════════════ TOP TWO JUGS ══════════════ -->
<div class="top-row">

  <!-- ── CHANGE jug (left) ── -->
  <div class="jug-col">
    <div class="jug-label change">Things I'd like to change</div>
    <div class="jug-wrap" id="changeWrap"
         ondragover="jugDragOver(event,'change')"
         ondragleave="jugDragLeave(event,'change')"
         ondrop="jugDrop(event,'change')">

      <svg class="jug-svg" viewBox="0 0 200 310" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <!-- Interior clip (jug body only, no neck) -->
          <clipPath id="cBodyClip">
            <path d="M52,80 C48,80 36,96 34,144 L28,270 Q27,286 52,286 L148,286 Q173,286 172,270 L166,144 C164,96 152,80 148,80 Z"/>
          </clipPath>
          <!-- Gradient for glass material -->
          <linearGradient id="cGlass" x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%"   stop-color="rgba(200,230,255,.16)"/>
            <stop offset="14%"  stop-color="rgba(200,230,255,.05)"/>
            <stop offset="86%"  stop-color="rgba(200,230,255,.03)"/>
            <stop offset="100%" stop-color="rgba(200,230,255,.12)"/>
          </linearGradient>
          <!-- Neck clip -->
          <clipPath id="cNeckClip">
            <rect x="66" y="38" width="68" height="46" rx="9"/>
          </clipPath>
          <filter id="cShadow" x="-15%" y="-8%" width="130%" height="130%">
            <feDropShadow dx="0" dy="5" stdDeviation="7" flood-color="rgba(0,0,0,.55)"/>
          </filter>
        </defs>

        <!-- ── Empty interior (very faint tint) ── -->
